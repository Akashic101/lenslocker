# Optional for Docker: if this file exists next to docker-compose.yml, Compose uses it to override
# variables (e.g. BETTER_AUTH_SECRET, ORIGIN). You do not need .env to run `docker compose up -d`
# after a fresh clone — defaults in docker-compose.yml are enough for a local trial.
#
# For local development with Bun on the host, copy this file to .env and adjust paths below.

# Drizzle
DATABASE_URL=local.db

# Docker Compose: use paths inside the container (see docker-compose.example.yaml), e.g.
# DATABASE_URL=/data/lenslocker.db
# TRANSFORMED_MEDIA_ROOT=/data/transformed
# RAW_UPLOAD_ROOT=/data/uploads/raw
# RAW_IMPORT_ROOT=/data/uploads/import
# LENSLOCKER_BACKUP_ROOT=/data/backups

# Absolute path to the transformed / RAW media tree (any depth of subfolders).
# Upload previews: <root>/upload-previews/<uuid>_thumb.<ext> (grid) and <uuid>_full.<ext> (modal; ext from settings: jpg, webp, avif, png).
# Leave unset to use <project>/static/transformed. In Docker, mount a volume and set e.g. /data/transformed
TRANSFORMED_MEDIA_ROOT=/data/transformed

# Uploaded RAW files (defaults to ./data/uploads/raw/<year>/<01-12>/)
RAW_UPLOAD_ROOT=

# Inbox for "Import from disk" on /upload (defaults to ./data/uploads/import). Files are moved into RAW_UPLOAD_ROOT after import.
RAW_IMPORT_ROOT=

# Public site URL (required in production). Better Auth uses this as baseURL. Dev falls back to http://localhost:5173 when empty.
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# After changing auth config, run: bun run auth:schema && bun run db:push (TTY) to apply user/session tables.

# Docker: set to 1 to skip automatic `drizzle-kit push` in the container entrypoint (you manage schema yourself).
# LENSLOCKER_SKIP_DB_PUSH=1
