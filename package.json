{
	"name": "lenslocker",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run",
		"test:coverage": "bun run test:unit -- --run --coverage --project server",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"wipe:uploads": "bun run scripts/wipe_uploads.ts",
		"knip": "knip",
		"translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@flowbite-svelte-plugins/chart": "^0.2.4",
		"@inlang/cli": "3.1.9",
		"@inlang/paraglide-js": "^2.10.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"better-auth": "~1.4.21",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.33.0",
		"flowbite-svelte-icons": "^3.1.0",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"apexcharts": "^5.10.4",
		"better-sqlite3": "^12.6.2",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"exifr": "^7.1.3",
		"exiftool-vendored": "^35.15.1",
		"jszip": "^3.10.1",
		"knip": "^6.3.0",
		"sharp": "^0.34.5"
	}
}
